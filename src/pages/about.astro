---
import Base from '../layouts/Base.astro';

const values = [
  {
    title: 'Compassion first',
    body: 'We hire for kindness before anything else. Skills can be taught; a caring heart can’t.',
    icon: '<path d="M12 20.5l-8-8a5 5 0 0 1 7-7l1 1 1-1a5 5 0 0 1 7 7z"/>',
  },
  {
    title: 'Consistency',
    body: 'The same caregiver, on time, week after week. Dependable care is the whole job.',
    icon: '<path d="M4 12a8 8 0 0 1 13.7-5.7L20 8"/><path d="M20 3v5h-5"/><path d="M20 12a8 8 0 0 1-13.7 5.7L4 16"/><path d="M4 21v-5h5"/>',
  },
  {
    title: 'Honesty',
    body: 'We tell families the truth — the good days and the hard ones — even when it’s uncomfortable.',
    icon: '<path d="M12 3l7 3v5c0 4.6-3.1 7.7-7 9-3.9-1.3-7-4.4-7-9V6z"/><path d="M9 12l2 2 4-4"/>',
  },
  {
    title: 'Independence at home',
    body: 'Growing older or living with a disability shouldn’t mean leaving the home you love.',
    icon: '<path d="M3 11l9-8 9 8"/><path d="M5 10v10h14V10"/><path d="M10 20v-6h4v6"/>',
  },
];
---
<Base
  title="About — Helen's Home Care"
  description="Helen's Home Care LLC is a family-owned, Texas-licensed personal assistance services agency helping seniors and individuals in need live well at home across the Dallas–Fort Worth area."
>
  <!-- Hero -->
  <section class="bg-mist/40">
    <div class="mx-auto max-w-6xl px-5 py-16 md:py-20">
      <div class="roofline" aria-hidden="true"></div>
      <h1 class="mt-6 font-display text-4xl text-navy md:text-5xl">About Helen's Home Care</h1>
      <p class="mt-5 max-w-2xl text-lg leading-relaxed text-slate">
        A family-owned, Texas-licensed home care agency helping seniors and
        individuals in need live safely and comfortably at home across the
        Dallas–Fort Worth area.
      </p>
    </div>
  </section>

  <!-- Story + details -->
  <section class="mx-auto max-w-6xl px-5 py-16">
    <img
      src="/images/care-groceries.jpg"
      alt="A Helen's Home Care caregiver bringing groceries to a senior man at home"
      width="1600"
      height="1061"
      class="mb-14 h-72 w-full rounded-xl object-cover object-top shadow-sm md:h-[460px]"
      loading="eager"
    />
    <div class="grid gap-14 md:grid-cols-[1.4fr_1fr]">
      <div class="space-y-6 text-lg leading-relaxed text-slate">
        <p>
          Helen's Home Care is a family-owned personal assistance services
          agency based in Dallas, Texas. We started with a simple conviction:
          growing older — or living with a disability — shouldn't mean leaving
          home, and families shouldn't have to carry the weight of daily care
          alone.
        </p>
        <p>
          We're licensed by the Texas Health and Human Services Commission as
          a Home and Community Support Services Agency providing Personal
          Assistance Services — the state's licensing category for the
          non-medical support we deliver: personal care, meals, companionship,
          errands, and household help.
        </p>
        <p>
          What makes care good isn't complicated. It's the same caregiver
          showing up on time, week after week. It's noticing when someone seems
          quieter than usual and telling the family. It's treating a person's
          home, routine, and preferences with respect. That's the standard we
          hold ourselves to.
        </p>
      </div>

      <aside class="space-y-8">
        <div class="rounded-xl border border-mist bg-white p-7 shadow-sm">
          <h2 class="text-sm font-semibold uppercase tracking-wide text-sky">Leadership</h2>
          <dl class="mt-4 space-y-4">
            <div>
              <dt class="font-semibold text-navy">Alex Maouene</dt>
              <dd class="text-base text-slate">Owner &amp; Administrator</dd>
            </div>
            <div>
              <dt class="font-semibold text-navy">Monteca Oleko</dt>
              <dd class="text-base text-slate">Alternate Administrator</dd>
            </div>
          </dl>
        </div>

        <div class="rounded-xl border border-mist bg-white p-7 shadow-sm">
          <h2 class="text-sm font-semibold uppercase tracking-wide text-sky">Service area</h2>
          <p class="mt-3 text-base leading-relaxed text-slate">
            Dallas and surrounding communities in the Dallas–Fort Worth
            metroplex. Not sure if you're in our area? Call us — if we can't
            serve you, we'll help you find someone who can.
          </p>
        </div>

        <div class="rounded-xl border border-mist bg-white p-7 shadow-sm">
          <h2 class="text-sm font-semibold uppercase tracking-wide text-sky">Our caregivers</h2>
          <p class="mt-3 text-base leading-relaxed text-slate">
            Every caregiver is screened, background-checked, trained, and
            employed by us — never subcontracted. We match caregivers to
            clients by needs and personality, and we keep the match consistent.
          </p>
        </div>
      </aside>
    </div>
  </section>

  <!-- Mission & Vision -->
  <section class="bg-mist/40 py-16 md:py-20">
    <div class="mx-auto max-w-6xl px-5">
      <div class="grid gap-8 md:grid-cols-2">
        <div class="rounded-2xl border border-mist bg-white p-8 shadow-sm md:p-10">
          <h2 class="text-sm font-semibold uppercase tracking-wide text-sky">Our mission</h2>
          <p class="mt-4 font-display text-2xl leading-snug text-navy md:text-[1.7rem]">
            To help seniors and individuals in need live safely and comfortably
            at home — with the everyday support they need and the dignity they
            deserve — while giving their families peace of mind.
          </p>
        </div>
        <div class="rounded-2xl border border-mist bg-white p-8 shadow-sm md:p-10">
          <h2 class="text-sm font-semibold uppercase tracking-wide text-sky">Our vision</h2>
          <p class="mt-4 font-display text-2xl leading-snug text-navy md:text-[1.7rem]">
            A Dallas–Fort Worth where growing older, or living with a
            disability, never means leaving the home and the life you love.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- What we stand for -->
  <section class="mx-auto max-w-6xl px-5 py-16 md:py-20">
    <div class="roofline" aria-hidden="true"></div>
    <h2 class="mt-6 font-display text-3xl text-navy">What we stand for</h2>
    <p class="mt-4 max-w-2xl text-lg leading-relaxed text-slate">
      Four commitments shape every visit, every hire, and every care plan.
    </p>
    <div class="mt-12 grid gap-x-10 gap-y-10 sm:grid-cols-2">
      {values.map((v) => (
        <div class="flex gap-4">
          <span class="flex h-12 w-12 shrink-0 items-center justify-center rounded-full bg-mist text-brand">
            <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={v.icon}></svg>
          </span>
          <div>
            <h3 class="text-xl font-semibold text-navy">{v.title}</h3>
            <p class="mt-2 leading-relaxed text-slate">{v.body}</p>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- CTA -->
  <section class="mx-auto max-w-6xl px-5 pb-20">
    <div class="rounded-xl bg-navy px-8 py-12 text-center md:px-16 md:py-14">
      <h2 class="font-display text-3xl text-white">Meet us before you decide</h2>
      <p class="mx-auto mt-4 max-w-xl text-lg leading-relaxed text-mist/90">
        The free in-home consultation is as much for you to interview us as it
        is for us to understand your family.
      </p>
      <div class="mt-8 flex flex-wrap items-center justify-center gap-4">
        <a
          href="/contact"
          class="rounded-md bg-white px-6 py-3.5 text-base font-semibold text-navy transition-colors hover:bg-mist"
        >
          Schedule a visit
        </a>
        <a href="tel:+12145550123" class="text-base font-semibold text-sky hover:text-white">
          (214) 555-0123
        </a>
      </div>
    </div>
  </section>
</Base>
