---
import Base from '../layouts/Base.astro';
---
<Base
  title="Contact — Helen's Home Care"
  description="Request a free in-home consultation with Helen's Home Care, or call (214) 555-0123. Serving the Dallas–Fort Worth area."
>
  <section class="bg-mist/40">
    <div class="mx-auto max-w-6xl px-5 py-16 md:py-20">
      <div class="roofline" aria-hidden="true"></div>
      <h1 class="mt-6 font-display text-4xl text-navy md:text-5xl">Contact us</h1>
      <p class="mt-5 max-w-2xl text-lg leading-relaxed text-slate">
        The fastest way to reach us is a phone call. Prefer to write? Use the
        form and we'll respond within one business day.
      </p>
    </div>
  </section>

  <section class="mx-auto max-w-6xl px-5 py-16">
    <div class="grid gap-14 md:grid-cols-[1fr_1.3fr]">
      <div class="space-y-8">
        <div>
          <h2 class="text-sm font-semibold uppercase tracking-wide text-sky">Phone</h2>
          <a href="tel:+12145550123" class="mt-2 block font-display text-3xl text-navy hover:text-brand">
            (214) 555-0123
          </a>
          <p class="mt-2 text-[15px] text-slate">Monday–Friday, 8am–6pm · After-hours voicemail returned next morning</p>
        </div>
        <div>
          <h2 class="text-sm font-semibold uppercase tracking-wide text-sky">Email</h2>
          <a href="mailto:care@helenshomecare.com" class="mt-2 block text-lg font-semibold text-brand hover:text-navy">
            care@helenshomecare.com
          </a>
        </div>
        <div>
          <h2 class="text-sm font-semibold uppercase tracking-wide text-sky">Service area</h2>
          <p class="mt-2 text-lg text-ink">Dallas–Fort Worth metroplex, Texas</p>
        </div>
      </div>

      <form
        class="rounded-xl border border-mist bg-white p-7 shadow-sm md:p-9"
        action="https://formspree.io/f/YOUR_FORM_ID"
        method="POST"
      >
        <h2 class="font-display text-2xl text-navy">Request a free consultation</h2>

        <div class="mt-7 grid gap-6 sm:grid-cols-2">
          <div>
            <label for="name" class="block text-sm font-semibold text-navy">Your name</label>
            <input
              id="name" name="name" type="text" required autocomplete="name"
              class="mt-2 w-full rounded-md border border-slate/40 px-4 py-3 text-[15px] focus:border-brand"
            />
          </div>
          <div>
            <label for="phone" class="block text-sm font-semibold text-navy">Phone</label>
            <input
              id="phone" name="phone" type="tel" required autocomplete="tel"
              class="mt-2 w-full rounded-md border border-slate/40 px-4 py-3 text-[15px] focus:border-brand"
            />
          </div>
        </div>

        <div class="mt-6">
          <label for="email" class="block text-sm font-semibold text-navy">Email</label>
          <input
            id="email" name="email" type="email" autocomplete="email"
            class="mt-2 w-full rounded-md border border-slate/40 px-4 py-3 text-[15px] focus:border-brand"
          />
        </div>

        <div class="mt-6">
          <label for="care-for" class="block text-sm font-semibold text-navy">Who needs care?</label>
          <select
            id="care-for" name="care-for"
            class="mt-2 w-full rounded-md border border-slate/40 bg-white px-4 py-3 text-[15px] focus:border-brand"
          >
            <option>A parent</option>
            <option>A spouse</option>
            <option>Myself</option>
            <option>Someone else</option>
          </select>
        </div>

        <div class="mt-6">
          <label for="message" class="block text-sm font-semibold text-navy">
            Tell us a little about your situation <span class="font-normal text-slate">(optional)</span>
          </label>
          <textarea
            id="message" name="message" rows="4"
            class="mt-2 w-full rounded-md border border-slate/40 px-4 py-3 text-[15px] focus:border-brand"
            placeholder="What does a typical day look like? Where would a hand help most?"
          ></textarea>
        </div>

        <button
          type="submit"
          class="mt-8 w-full rounded-md bg-brand px-6 py-3.5 text-base font-semibold text-white transition-colors hover:bg-navy"
        >
          Send request
        </button>

        <p class="mt-4 text-sm leading-relaxed text-slate">
          Please don't include medical or health details in this form. We'll
          discuss care needs by phone.
        </p>
      </form>
    </div>
  </section>
</Base>
