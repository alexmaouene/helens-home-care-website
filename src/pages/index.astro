---
import Base from '../layouts/Base.astro';
import { BOOKING_URL } from '../consts';

const helpWith = [
  'Bathing, dressing & grooming',
  'Meal preparation',
  'Medication reminders',
  'Light housekeeping',
  'Errands & transportation',
  'Companionship',
];

const reasons = [
  {
    title: 'The same caregiver, every time',
    body: 'Consistency is the whole job. We match one caregiver to your family and protect that match — so your parent is never re-explaining themselves to a stranger.',
  },
  {
    title: 'Our caregivers work for us — not a roster',
    body: 'Every caregiver is screened, background-checked, trained, and employed by Helen’s Home Care. We never subcontract the person who walks through your door.',
  },
  {
    title: 'Licensed, insured, and family-owned',
    body: 'Licensed by the Texas Health and Human Services Commission as a Home and Community Support Services Agency. A family business, not a franchise.',
  },
  {
    title: 'Care that flexes when life does',
    body: 'A few hours a week or support every day. Needs change — schedules change with them, without penalties or renegotiating a contract.',
  },
  {
    title: "You're never left in the dark",
    body: 'We tell you what we notice: the good days, the off days, and the small changes worth a conversation — especially if you live far away.',
  },
];

const steps = [
  {
    n: '1',
    title: 'Call us',
    body: 'Tell us about your parent or loved one — what a typical day looks like and where they need a hand. No obligation, no pressure.',
  },
  {
    n: '2',
    title: 'Free in-home visit',
    body: 'We come to you, meet the family, and build a care plan around their routine, preferences, and schedule.',
  },
  {
    n: '3',
    title: 'Care begins',
    body: 'A carefully matched caregiver starts on your schedule — a few hours a week or every day. Adjust anytime.',
  },
];
---
<Base
  title="Helen's Home Care — Non-Medical Home Care in Dallas, TX"
  description="Helen's Home Care provides licensed, non-medical personal assistance services in the Dallas–Fort Worth area: bathing and dressing assistance, meal preparation, companionship, and more."
>
  <!-- Hero -->
  <section class="bg-mist/40">
    <div class="mx-auto grid max-w-6xl items-center gap-12 px-5 py-16 md:grid-cols-[1.2fr_1fr] md:py-24">
      <div>
        <div class="roofline" aria-hidden="true"></div>
        <h1 class="mt-6 font-display text-4xl leading-[1.12] text-navy md:text-[3.4rem]">
          Help at home,<br />so home stays home.
        </h1>
        <p class="mt-6 max-w-lg text-lg leading-relaxed text-slate">
          Helen's Home Care provides non-medical personal assistance for older
          adults in the Dallas–Fort Worth area — the everyday support that lets
          your parent stay safely in the house they love.
        </p>
        <div class="mt-9 flex flex-wrap items-center gap-4">
          <a
            href={BOOKING_URL}
            target="_blank"
            rel="noopener"
            class="rounded-md bg-brand px-6 py-3.5 text-base font-semibold text-white transition-colors hover:bg-navy"
          >
            Book a free consultation
          </a>
          <a href="tel:+12145550123" class="text-base font-semibold text-brand hover:text-navy">
            or call (214) 555-0123
          </a>
        </div>
        <p class="mt-8 text-sm text-slate">
          Licensed by Texas HHSC · Insured · Family-owned
        </p>
      </div>

      <div class="rounded-xl border border-mist bg-white p-7 shadow-sm md:p-8">
        <h2 class="font-display text-xl text-navy">What we help with</h2>
        <ul class="mt-5 space-y-3.5">
          {helpWith.map((item) => (
            <li class="flex items-start gap-3 text-base text-ink">
              <svg class="mt-0.5 h-5 w-5 shrink-0 text-sky" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M4 10.5l4 4 8-9" />
              </svg>
              {item}
            </li>
          ))}
        </ul>
        <a href="/services" class="mt-6 inline-block text-base font-semibold text-brand hover:text-navy">
          See all services →
        </a>
      </div>
    </div>
  </section>

  <!-- Hero image -->
  <section class="mx-auto max-w-6xl px-5">
    <img
      src="/images/care-dancing.jpg"
      alt="A Helen's Home Care caregiver sharing a dance with an older woman in her living room"
      width="1400"
      height="933"
      class="h-64 w-full rounded-xl object-cover shadow-sm md:h-[440px]"
      loading="eager"
    />
  </section>

  <!-- Who it's for -->
  <section class="mx-auto max-w-6xl px-5 py-20">
    <div class="grid gap-12 md:grid-cols-[1fr_1.4fr]">
      <div>
        <div class="roofline" aria-hidden="true"></div>
        <h2 class="mt-6 font-display text-3xl leading-snug text-navy">
          For families doing their best from near or far
        </h2>
      </div>
      <div class="space-y-5 text-lg leading-relaxed text-slate">
        <p>
          Maybe Mom is still sharp but shouldn't be on a step stool. Maybe Dad
          skips meals when no one's there to share them. Maybe you're an hour
          away — or a flight away — and the worry rides with you everywhere.
        </p>
        <p>
          That's the gap we fill. Our caregivers handle the daily tasks that
          have become hard, keep good company, and keep you in the loop — so
          your visits can be about family again, not chores.
        </p>
      </div>
    </div>
  </section>

  <!-- Why families choose us -->
  <section class="bg-mist/40 py-20">
    <div class="mx-auto max-w-6xl px-5">
      <div class="roofline" aria-hidden="true"></div>
      <h2 class="mt-6 font-display text-3xl text-navy">Why families choose us</h2>
      <div class="mt-12 grid gap-12 md:grid-cols-[1fr_1.3fr] md:items-start">
        <img
          src="/images/care-companionship.jpg"
          alt="A Helen's Home Care caregiver helping two older adults with an activity at the kitchen table"
          width="1400"
          height="990"
          class="h-72 w-full rounded-xl object-cover shadow-sm md:h-[520px]"
          loading="lazy"
        />
        <ul class="space-y-8">
          {reasons.map((r) => (
            <li>
              <h3 class="flex items-start gap-3 text-xl font-semibold text-navy">
                <svg class="mt-1 h-5 w-5 shrink-0 text-sky" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M4 10.5l4 4 8-9" />
                </svg>
                {r.title}
              </h3>
              <p class="mt-2 leading-relaxed text-slate">{r.body}</p>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <!-- What care costs families -->
  <section class="mx-auto max-w-6xl px-5 py-20">
    <div class="grid items-center gap-12 md:grid-cols-[1fr_1.2fr]">
      <img
        src="/images/care-friends.jpg"
        alt="Two older women smiling together, arm in arm"
        width="1400"
        height="933"
        class="h-72 w-full rounded-xl object-cover shadow-sm md:h-[440px]"
        loading="lazy"
      />
      <div>
        <div class="roofline" aria-hidden="true"></div>
        <h2 class="mt-6 font-display text-3xl leading-snug text-navy">
          We know what saying yes to care can cost
        </h2>
        <div class="mt-6 space-y-5 text-lg leading-relaxed text-slate">
          <p>
            Families tell us things they don't say out loud very often. That
            the savings have gone quiet. That they retired earlier than they
            meant to. That they've sat at the kitchen table and talked about
            selling the house — the one their parents worked a lifetime for —
            because care has to come from somewhere.
          </p>
          <p>
            We don't take that lightly. When a family stretches that far for
            someone they love, the least we owe them is care worth the
            sacrifice: the same caregiver, on time, treating your parent with
            respect, and telling you the truth about how they're really doing.
          </p>
          <p>
            This is a hard season, and we can't make that part easy. What we
            can do is make the care itself the one thing you never have to
            worry about — and if there's help you might qualify for, we'll
            point you toward it, even when it doesn't benefit us.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- How it works -->
  <section class="bg-mist/40 py-20">
    <div class="mx-auto max-w-6xl px-5">
      <div class="roofline" aria-hidden="true"></div>
      <h2 class="mt-6 font-display text-3xl text-navy">How care starts</h2>
      <div class="mt-12 grid gap-10 md:grid-cols-3">
        {steps.map((s) => (
          <div>
            <span class="flex h-11 w-11 items-center justify-center rounded-full bg-brand font-display text-lg text-white">
              {s.n}
            </span>
            <h3 class="mt-5 text-xl font-semibold text-navy">{s.title}</h3>
            <p class="mt-3 leading-relaxed text-slate">{s.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA band -->
  <section class="mx-auto max-w-6xl px-5 py-20">
    <div class="rounded-xl bg-navy px-8 py-12 text-center md:px-16 md:py-14">
      <h2 class="font-display text-3xl text-white">Talk to us about your family</h2>
      <p class="mx-auto mt-4 max-w-xl text-lg leading-relaxed text-mist/90">
        A ten-minute call is enough to tell you whether we're the right fit.
        There's no cost and no commitment.
      </p>
      <div class="mt-8 flex flex-wrap items-center justify-center gap-4">
        <a
          href={BOOKING_URL}
          target="_blank"
          rel="noopener"
          class="rounded-md bg-white px-6 py-3.5 text-base font-semibold text-navy transition-colors hover:bg-mist"
        >
          Book a free consultation
        </a>
        <a href="tel:+12145550123" class="text-base font-semibold text-sky hover:text-white">
          (214) 555-0123
        </a>
      </div>
    </div>
  </section>
</Base>
