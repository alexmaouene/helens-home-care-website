---
import Base from '../layouts/Base.astro';

const perks = [
  {
    title: 'Consistent clients & schedules',
    body: 'We match you with clients you see regularly, on a schedule that fits your life — not a different address every day.',
  },
  {
    title: 'You work for us, not a gig app',
    body: 'Caregivers are our employees — screened, trained, and supported by a real office you can reach.',
  },
  {
    title: 'Work that matters, close to home',
    body: 'Serving the Dallas–Fort Worth area. Help seniors and individuals in need stay safe in the homes they love — a few hours a week or full-time.',
  },
];

// Values must match the Jotform checkbox options exactly (incl. straight apostrophes).
const qualifications = [
  'Legally authorized to work in the U.S.',
  "Valid driver's license & insured vehicle",
  'High school diploma or GED',
  'Reliable, punctual, and a non-smoker on duty',
  'Compassion and patience with seniors and individuals in need',
  'CNA license',
  'CPR / First Aid certified',
];

const availability = [
  'Full-time',
  'Part-time',
  'Weekends',
  'Overnight',
  'As-needed (PRN)',
];

const inputClass =
  'mt-2 w-full rounded-md border border-slate/40 px-4 py-3 text-base text-ink focus:border-brand';
const subLabel = 'mt-1 block text-sm text-slate';
---
<Base
  title="Careers — Helen's Home Care"
  description="Join the Helen's Home Care team as a caregiver in the Dallas–Fort Worth area. Apply to help seniors and individuals in need stay safely in the homes they love."
>
  <!-- Hero -->
  <section class="bg-mist/40">
    <div class="mx-auto grid max-w-6xl items-center gap-10 px-5 py-14 md:grid-cols-2 md:py-20">
      <img
        src="/images/care-garden.jpg"
        alt="A Helen's Home Care caregiver walking with a senior woman through her garden"
        width="1600"
        height="900"
        class="h-72 w-full rounded-xl object-cover object-top shadow-sm md:h-[460px]"
        loading="eager"
      />
      <div>
        <div class="roofline" aria-hidden="true"></div>
        <h1 class="mt-6 font-display text-4xl text-navy md:text-5xl">Join Our Team</h1>
        <p class="mt-4 text-xl font-semibold text-brand md:text-2xl">
          Make a Difference in the Lives of Seniors and Individuals in Need
        </p>
        <p class="mt-5 text-lg leading-relaxed text-slate">
          At Helen's Home Care, we're passionate about helping seniors and
          individuals in need live independently and with dignity.
        </p>
        <p class="mt-4 text-lg leading-relaxed text-slate">
          If you share our commitment to making a positive impact, we'd love to
          hear from you.
        </p>
        <p class="mt-4 text-lg leading-relaxed text-slate">
          Fill out the application below to join a team that values compassion,
          professionalism, and community.
        </p>
      </div>
    </div>
  </section>

  <!-- Why work with us -->
  <section class="mx-auto max-w-6xl px-5 py-16">
    <div class="roofline" aria-hidden="true"></div>
    <h2 class="mt-6 font-display text-3xl text-navy">Why caregivers choose Helen's</h2>
    <div class="mt-10 grid gap-10 md:grid-cols-3">
      {perks.map((p) => (
        <div>
          <h3 class="flex items-start gap-3 text-xl font-semibold text-navy">
            <svg class="mt-1 h-5 w-5 shrink-0 text-sky" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M4 10.5l4 4 8-9" />
            </svg>
            {p.title}
          </h3>
          <p class="mt-2 leading-relaxed text-slate">{p.body}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- Application form -->
  <section class="bg-mist/40 py-16 md:py-20">
    <div class="mx-auto max-w-3xl px-5">
      <div class="rounded-2xl border border-mist bg-white px-6 py-10 shadow-sm md:px-12 md:py-12">
        <div class="text-center">
          <div class="roofline mx-auto" aria-hidden="true"></div>
          <h2 class="mt-5 font-display text-3xl text-navy md:text-4xl">Caregiver application</h2>
          <p class="mx-auto mt-3 max-w-md text-base text-slate">
            Fields marked <span class="text-brand">*</span> are required —
            everything else is optional but helps us get to know you.
          </p>
        </div>

        <form
          class="mt-10 text-left"
          action="https://submit.jotform.com/submit/262030348518049"
          method="POST"
        >
          <input type="hidden" name="formID" value="262030348518049" />
          <input type="hidden" name="simple_spc" value="262030348518049-262030348518049" />
          <!-- Name -->
          <fieldset class="border-0 p-0">
            <legend class="text-sm font-semibold text-navy">Full name <span class="text-brand">*</span></legend>
            <div class="mt-2 grid gap-4 sm:grid-cols-3">
              <div>
                <input id="first-name" name="q3_q3_fullname1[first]" type="text" required autocomplete="given-name" class={inputClass} placeholder="First" aria-label="First name" />
              </div>
              <div>
                <input id="middle-name" name="q3_q3_fullname1[middle]" type="text" autocomplete="additional-name" class={inputClass} placeholder="Middle" aria-label="Middle name" />
              </div>
              <div>
                <input id="last-name" name="q3_q3_fullname1[last]" type="text" required autocomplete="family-name" class={inputClass} placeholder="Last" aria-label="Last name" />
              </div>
            </div>
          </fieldset>

          <!-- Phone + Email -->
          <div class="mt-6 grid gap-4 sm:grid-cols-2">
            <div>
              <label for="phone" class="block text-sm font-semibold text-navy">Phone number <span class="text-brand">*</span></label>
              <input id="phone" name="q4_q4_phone2[full]" type="tel" required autocomplete="tel" class={inputClass} placeholder="(555) 123-4567" />
            </div>
            <div>
              <label for="email" class="block text-sm font-semibold text-navy">Email <span class="text-brand">*</span></label>
              <input id="email" name="q5_q5_email3" type="email" required autocomplete="email" class={inputClass} placeholder="you@example.com" />
            </div>
          </div>

          <!-- DOB -->
          <fieldset class="mt-6 border-0 p-0">
            <legend class="text-sm font-semibold text-navy">Date of birth <span class="text-brand">*</span></legend>
            <div class="mt-2 flex max-w-xs gap-3">
              <input name="q6_q6_datetime4[month]" type="number" min="1" max="12" required inputmode="numeric" class={inputClass} placeholder="MM" aria-label="Birth month" />
              <input name="q6_q6_datetime4[day]" type="number" min="1" max="31" required inputmode="numeric" class={inputClass} placeholder="DD" aria-label="Birth day" />
              <input name="q6_q6_datetime4[year]" type="number" min="1900" max="2010" required inputmode="numeric" class={inputClass} placeholder="YYYY" aria-label="Birth year" />
            </div>
            <span class={subLabel}>You must be 18 or older to apply.</span>
          </fieldset>

          <!-- Address -->
          <fieldset class="mt-6 border-0 p-0">
            <legend class="text-sm font-semibold text-navy">Home address <span class="text-brand">*</span></legend>
            <input name="q7_q7_address5[addr_line1]" type="text" required autocomplete="address-line1" class={inputClass} placeholder="Street address" aria-label="Street address" />
            <input name="q7_q7_address5[addr_line2]" type="text" autocomplete="address-line2" class={inputClass} placeholder="Apt, suite, etc. (optional)" aria-label="Street address line 2" />
            <div class="mt-4 grid gap-4 sm:grid-cols-3">
              <input name="q7_q7_address5[city]" type="text" required autocomplete="address-level2" class="rounded-md border border-slate/40 px-4 py-3 text-base text-ink focus:border-brand" placeholder="City" aria-label="City" />
              <input name="q7_q7_address5[state]" type="text" required autocomplete="address-level1" class="rounded-md border border-slate/40 px-4 py-3 text-base text-ink focus:border-brand" placeholder="State" aria-label="State" />
              <input name="q7_q7_address5[postal]" type="text" required autocomplete="postal-code" class="rounded-md border border-slate/40 px-4 py-3 text-base text-ink focus:border-brand" placeholder="ZIP code" aria-label="ZIP code" />
            </div>
            <input type="hidden" name="q7_q7_address5[country]" value="United States" />
          </fieldset>

          <!-- Availability + experience -->
          <div class="mt-6 grid gap-4 sm:grid-cols-2">
            <div>
              <label for="availability" class="block text-sm font-semibold text-navy">Availability</label>
              <select id="availability" name="q9_q9_dropdown7" class="mt-2 w-full rounded-md border border-slate/40 bg-white px-4 py-3 text-base text-ink focus:border-brand">
                <option value="" selected disabled>Please select…</option>
                {availability.map((a) => <option value={a}>{a}</option>)}
              </select>
            </div>
            <div>
              <label for="experience" class="block text-sm font-semibold text-navy">Years of caregiving experience</label>
              <input id="experience" name="q10_q10_number8" type="number" min="0" max="60" class={inputClass} placeholder="e.g. 3" />
            </div>
          </div>

          <!-- Own a car -->
          <fieldset class="mt-6 border-0 p-0">
            <legend class="text-sm font-semibold text-navy">Do you own a car? <span class="text-brand">*</span></legend>
            <div class="mt-3 flex flex-wrap gap-x-8 gap-y-3">
              {['Yes', 'No'].map((opt) => (
                <label class="flex items-center gap-2.5 text-base text-ink">
                  <input type="radio" name="q12_q12_radio10" value={opt} required class="h-4 w-4 accent-brand" />
                  {opt}
                </label>
              ))}
            </div>
          </fieldset>

          <!-- Qualifications -->
          <fieldset class="mt-6 border-0 p-0">
            <legend class="text-sm font-semibold text-navy">Which of these apply to you? <span class="font-normal text-slate">(check all that apply)</span></legend>
            <div class="mt-3 grid gap-x-8 gap-y-3 sm:grid-cols-2">
              {qualifications.map((q) => (
                <label class="flex items-start gap-2.5 text-base text-ink">
                  <input type="checkbox" name="q13_q13_checkbox11[]" value={q} class="mt-1 h-4 w-4 shrink-0 accent-brand" />
                  {q}
                </label>
              ))}
            </div>
          </fieldset>

          <!-- Work authorization -->
          <fieldset class="mt-6 border-0 p-0">
            <legend class="text-sm font-semibold text-navy">Are you legally authorized to work in the U.S.? <span class="text-brand">*</span></legend>
            <div class="mt-3 flex flex-wrap gap-x-8 gap-y-3">
              {['Yes', 'No'].map((opt) => (
                <label class="flex items-center gap-2.5 text-base text-ink">
                  <input type="radio" name="q14_q14_radio12" value={opt} required class="h-4 w-4 accent-brand" />
                  {opt}
                </label>
              ))}
            </div>
          </fieldset>

          <!-- Felony -->
          <fieldset class="mt-6 border-0 p-0">
            <legend class="text-sm font-semibold text-navy">Have you ever been convicted of a felony? <span class="text-brand">*</span></legend>
            <div class="mt-3 flex flex-wrap gap-x-8 gap-y-3">
              {['Yes', 'No'].map((opt) => (
                <label class="flex items-center gap-2.5 text-base text-ink">
                  <input type="radio" name="q15_q15_radio13" value={opt} required class="h-4 w-4 accent-brand" />
                  {opt}
                </label>
              ))}
            </div>
            <span class={subLabel}>A conviction won't automatically disqualify you — we consider each application individually.</span>
          </fieldset>

          <!-- Message -->
          <div class="mt-6">
            <label for="message" class="block text-sm font-semibold text-navy">
              Tell us a little about yourself <span class="font-normal text-slate">(optional)</span>
            </label>
            <textarea id="message" name="q17_tellUs" rows="4" class={inputClass} placeholder="Why do you want to be a caregiver? What kind of work are you looking for?"></textarea>
          </div>

          <button
            type="submit"
            class="mt-8 w-full rounded-md bg-brand px-6 py-3.5 text-base font-semibold text-white transition-colors hover:bg-navy"
          >
            Submit application
          </button>

          <p class="mt-4 text-center text-sm leading-relaxed text-slate">
            Helen's Home Care is an equal-opportunity employer. Your information
            is kept confidential and used only to consider your application.
          </p>
        </form>
      </div>

      <p class="mt-8 text-center text-base text-slate">
        Questions about caregiving with us? Call
        <a href="tel:+12145550123" class="font-semibold text-brand hover:text-navy">(214) 555-0123</a>.
      </p>
    </div>
  </section>
</Base>
