---
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
}

const { title, description } = Astro.props;
const nav = [
  { href: '/', label: 'Home' },
  { href: '/services', label: 'Services' },
  { href: '/about', label: 'About' },
  { href: '/careers', label: 'Careers' },
  { href: '/contact', label: 'Contact' },
];
const current = Astro.url.pathname.replace(/\/$/, '') || '/';
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Atkinson+Hyperlegible:wght@400;700&family=Fraunces:opsz,wght@9..144,500;9..144,600&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="bg-white">
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:absolute focus:left-4 focus:top-4 focus:z-50 focus:bg-white focus:px-4 focus:py-2 focus:text-brand"
      >Skip to content</a
    >

    <header class="border-b border-mist">
      <div class="mx-auto flex max-w-6xl items-center justify-between px-5 py-4">
        <a href="/" class="flex items-center gap-3" aria-label="Helen's Home Care home">
          <svg class="h-12 w-auto shrink-0 md:h-14" viewBox="0 0 82 90" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <path d="M0 46 L41 8 L82 46 L82 90 L0 90 Z" fill="none" stroke="#185FA5" stroke-width="8" stroke-linejoin="round" stroke-linecap="round"/>
            <path d="M41 78 C32 68 19 62 19 49 C19 41 25 37 31 37 C36 37 40 40 41 44 C42 40 46 37 51 37 C57 37 63 41 63 49 C63 62 50 68 41 78 Z" fill="#378ADD"/>
          </svg>
          <span class="leading-none">
            <span class="block font-display text-3xl font-semibold text-navy md:text-[2.1rem]">Helen's</span>
            <span class="mt-1 block text-[11px] font-semibold uppercase tracking-[0.28em] text-sky md:text-xs">Home Care</span>
          </span>
        </a>

        <nav aria-label="Main">
          <!-- Desktop nav -->
          <ul class="hidden items-center gap-8 md:flex">
            {nav.map((item) => (
              <li>
                <a
                  href={item.href}
                  aria-current={current === item.href ? 'page' : undefined}
                  class:list={[
                    'text-base font-medium transition-colors hover:text-brand',
                    current === item.href ? 'text-brand' : 'text-ink',
                  ]}
                >
                  {item.label}
                </a>
              </li>
            ))}
            <li>
              <a
                href="tel:+12145550123"
                class="rounded-md bg-brand px-4 py-2.5 text-base font-semibold text-white transition-colors hover:bg-navy"
              >
                (214) 555-0123
              </a>
            </li>
          </ul>

          <!-- Mobile menu button -->
          <button
            id="menu-btn"
            class="flex h-11 w-11 items-center justify-center rounded-md text-navy md:hidden"
            aria-expanded="false"
            aria-controls="mobile-menu"
            aria-label="Open menu"
          >
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
              <line x1="4" y1="7" x2="20" y2="7" />
              <line x1="4" y1="12" x2="20" y2="12" />
              <line x1="4" y1="17" x2="20" y2="17" />
            </svg>
          </button>
        </nav>
      </div>

      <!-- Mobile menu -->
      <div id="mobile-menu" class="hidden border-t border-mist md:hidden">
        <ul class="space-y-1 px-5 py-4">
          {nav.map((item) => (
            <li>
              <a
                href={item.href}
                aria-current={current === item.href ? 'page' : undefined}
                class:list={[
                  'block rounded-md px-3 py-3 text-base font-medium',
                  current === item.href ? 'bg-mist text-brand' : 'text-ink hover:bg-mist',
                ]}
              >
                {item.label}
              </a>
            </li>
          ))}
          <li class="pt-2">
            <a
              href="tel:+12145550123"
              class="block rounded-md bg-brand px-3 py-3 text-center text-base font-semibold text-white"
            >
              Call (214) 555-0123
            </a>
          </li>
        </ul>
      </div>
    </header>

    <main id="main">
      <slot />
    </main>

    <footer class="mt-24 bg-navy text-white">
      <div class="mx-auto max-w-6xl px-5 py-14">
        <div class="grid gap-10 md:grid-cols-3">
          <div>
            <p class="font-display text-xl">Helen's Home Care</p>
            <p class="mt-3 max-w-xs text-base leading-relaxed text-mist/90">
              Non-medical personal assistance services for seniors and
              individuals in need in the
              Dallas–Fort Worth area, delivered at home.
            </p>
          </div>
          <div>
            <p class="text-sm font-semibold uppercase tracking-wide text-sky">Contact</p>
            <ul class="mt-3 space-y-2 text-base text-mist/90">
              <li><a href="tel:+12145550123" class="hover:text-white">(214) 555-0123</a></li>
              <li><a href="mailto:care@helenshomecaretx.com" class="hover:text-white">care@helenshomecaretx.com</a></li>
              <li>Dallas, Texas</li>
            </ul>
          </div>
          <div>
            <p class="text-sm font-semibold uppercase tracking-wide text-sky">Licensing</p>
            <p class="mt-3 text-base leading-relaxed text-mist/90">
              Licensed by the Texas Health and Human Services Commission as a
              Home and Community Support Services Agency — Personal Assistance
              Services.
            </p>
          </div>
        </div>
        <p class="mt-12 border-t border-white/15 pt-6 text-sm text-mist/70">
          © {new Date().getFullYear()} Helen's Home Care LLC. Helen's Home Care
          does not discriminate on the basis of race, color, national origin,
          age, disability, or sex.
        </p>
      </div>
    </footer>

    <script>
      const btn = document.getElementById('menu-btn');
      const menu = document.getElementById('mobile-menu');
      btn?.addEventListener('click', () => {
        const open = menu?.classList.toggle('hidden') === false;
        btn.setAttribute('aria-expanded', String(open));
        btn.setAttribute('aria-label', open ? 'Close menu' : 'Open menu');
      });
    </script>
  </body>
</html>
