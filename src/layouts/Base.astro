---
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
}

const { title, description } = Astro.props;
const nav = [
  { href: '/', label: 'Home' },
  { href: '/services', label: 'Services' },
  { href: '/about', label: 'About' },
  { href: '/contact', label: 'Contact' },
];
const current = Astro.url.pathname.replace(/\/$/, '') || '/';
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,500;9..144,600&family=Inter+Tight:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="bg-white">
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:absolute focus:left-4 focus:top-4 focus:z-50 focus:bg-white focus:px-4 focus:py-2 focus:text-brand"
      >Skip to content</a
    >

    <header class="border-b border-mist">
      <div class="mx-auto flex max-w-6xl items-center justify-between px-5 py-4">
        <a href="/" class="flex items-center" aria-label="Helen's Home Care home">
          <img src="/logo.svg" alt="Helen's Home Care" class="h-11 w-auto" />
        </a>

        <nav aria-label="Main">
          <!-- Desktop nav -->
          <ul class="hidden items-center gap-8 md:flex">
            {nav.map((item) => (
              <li>
                <a
                  href={item.href}
                  aria-current={current === item.href ? 'page' : undefined}
                  class:list={[
                    'text-[15px] font-medium transition-colors hover:text-brand',
                    current === item.href ? 'text-brand' : 'text-ink',
                  ]}
                >
                  {item.label}
                </a>
              </li>
            ))}
            <li>
              <a
                href="tel:+12145550123"
                class="rounded-md bg-brand px-4 py-2.5 text-[15px] font-semibold text-white transition-colors hover:bg-navy"
              >
                (214) 555-0123
              </a>
            </li>
          </ul>

          <!-- Mobile menu button -->
          <button
            id="menu-btn"
            class="flex h-11 w-11 items-center justify-center rounded-md text-navy md:hidden"
            aria-expanded="false"
            aria-controls="mobile-menu"
            aria-label="Open menu"
          >
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
              <line x1="4" y1="7" x2="20" y2="7" />
              <line x1="4" y1="12" x2="20" y2="12" />
              <line x1="4" y1="17" x2="20" y2="17" />
            </svg>
          </button>
        </nav>
      </div>

      <!-- Mobile menu -->
      <div id="mobile-menu" class="hidden border-t border-mist md:hidden">
        <ul class="space-y-1 px-5 py-4">
          {nav.map((item) => (
            <li>
              <a
                href={item.href}
                aria-current={current === item.href ? 'page' : undefined}
                class:list={[
                  'block rounded-md px-3 py-3 text-base font-medium',
                  current === item.href ? 'bg-mist text-brand' : 'text-ink hover:bg-mist',
                ]}
              >
                {item.label}
              </a>
            </li>
          ))}
          <li class="pt-2">
            <a
              href="tel:+12145550123"
              class="block rounded-md bg-brand px-3 py-3 text-center text-base font-semibold text-white"
            >
              Call (214) 555-0123
            </a>
          </li>
        </ul>
      </div>
    </header>

    <main id="main">
      <slot />
    </main>

    <footer class="mt-24 bg-navy text-white">
      <div class="mx-auto max-w-6xl px-5 py-14">
        <div class="grid gap-10 md:grid-cols-3">
          <div>
            <p class="font-display text-xl">Helen's Home Care LLC</p>
            <p class="mt-3 max-w-xs text-[15px] leading-relaxed text-mist/90">
              Non-medical personal assistance services for older adults in the
              Dallas–Fort Worth area, delivered at home.
            </p>
          </div>
          <div>
            <p class="text-sm font-semibold uppercase tracking-wide text-sky">Contact</p>
            <ul class="mt-3 space-y-2 text-[15px] text-mist/90">
              <li><a href="tel:+12145550123" class="hover:text-white">(214) 555-0123</a></li>
              <li><a href="mailto:care@helenshomecare.com" class="hover:text-white">care@helenshomecare.com</a></li>
              <li>Dallas, Texas</li>
            </ul>
          </div>
          <div>
            <p class="text-sm font-semibold uppercase tracking-wide text-sky">Licensing</p>
            <p class="mt-3 text-[15px] leading-relaxed text-mist/90">
              Licensed by the Texas Health and Human Services Commission as a
              Home and Community Support Services Agency — Personal Assistance
              Services. License #000000.
            </p>
          </div>
        </div>
        <p class="mt-12 border-t border-white/15 pt-6 text-sm text-mist/70">
          © {new Date().getFullYear()} Helen's Home Care LLC. Helen's Home Care
          does not discriminate on the basis of race, color, national origin,
          age, disability, or sex.
        </p>
      </div>
    </footer>

    <script>
      const btn = document.getElementById('menu-btn');
      const menu = document.getElementById('mobile-menu');
      btn?.addEventListener('click', () => {
        const open = menu?.classList.toggle('hidden') === false;
        btn.setAttribute('aria-expanded', String(open));
        btn.setAttribute('aria-label', open ? 'Close menu' : 'Open menu');
      });
    </script>
  </body>
</html>
